{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@opensearch/contracts": ["packages/contracts/src/index.ts"],
      "@opensearch/core": ["packages/core/src/index.ts"],
      "@opensearch/prompts": ["packages/prompts/src/index.ts"],
      "@opensearch/sdk": ["packages/sdk/src/index.ts"],
      "@opensearch/sources": ["packages/sources/src/index.ts"],
      "@opensearch/testkit": ["packages/testkit/src/index.ts"]
    }
  }
}
