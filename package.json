{
  "name": "@kagan-sh/opensearch",
  "version": "0.0.1",
  "description": "OpenCode plugin that combines session, web, and code search",
  "license": "MIT",
  "homepage": "https://kagan-sh.github.io/opensearch/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kagan-sh/opensearch.git"
  },
  "bugs": {
    "url": "https://github.com/kagan-sh/opensearch/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md",
    "SKILL.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun tsc",
    "typecheck": "bun tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:build": "mkdocs build --strict",
    "docs:serve": "mkdocs serve",
    "check": "bun run typecheck && bun run test && bun run build",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.27",
    "@opencode-ai/sdk": "1.2.27",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  }
}
